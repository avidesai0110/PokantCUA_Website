      <div className="grid gap-6 md:grid-cols-3">
        {features.map((f, i) => (
          <motion.div
            key={f.title}
            variants={fadeUp}
            transition={{ delay: i * 0.1 }}
            className="group rounded-2xl border border-white/10 bg-white/[0.03] p-8 transition-all duration-300 hover:border-blue-500/30 hover:bg-white/[0.05]"
          >
            <div className="mb-5 flex h-11 w-11 items-center justify-center rounded-xl bg-blue-500/10 text-blue-400">
              <f.icon size={22} />
            </div>
            <h3 className="mb-3 font-display text-lg font-semibold text-white">
              {f.title}
            </h3>
            <p className="text-sm leading-relaxed text-gray-400">{f.desc}</p>
          </motion.div>
        ))}
      </div>
    </Section>
  )
}

/* ─── How It Works ─── */
const steps = [
  {
    icon: Send,
    num: "01",
    title: "Send a task",
    desc: "Pass a URL, a plain-English instruction, and an optional output schema. That's it.",
  },
  {
    icon: Cpu,
    num: "02",
    title: "We handle the rest",
    desc: "Our AI navigates pages, fills forms, clicks buttons, and verifies results — with automatic retries on failure.",
  },
  {
    icon: FileJson,
    num: "03",
    title: "Get structured data",
    desc: "Receive validated JSON matching your schema. Every run is logged with screenshots and a full execution trace.",
  },
]

function HowItWorks() {
  return (
    <Section
      id="how-it-works"
      className="border-t border-white/5 py-24 md:py-32"
    >
      <div className="mx-auto max-w-6xl px-6">
        <motion.div variants={fadeUp} className="mb-16 text-center">
          <p className="mb-3 text-sm font-medium uppercase tracking-[0.15em] text-blue-400">
            How It Works
          </p>
          <h2 className="font-display text-3xl font-bold tracking-tight text-white md:text-5xl">
            Three steps. Zero config.
          </h2>
        </motion.div>

        <div className="grid gap-12 md:grid-cols-3">
          {steps.map((s, i) => (
            <motion.div key={s.num} variants={fadeUp} transition={{ delay: i * 0.12 }}>
              <span className="font-display text-5xl font-bold text-blue-600/20">
                {s.num}
              </span>
              <div className="mt-4 flex items-center gap-3">
                <s.icon size={20} className="text-blue-400" />
                <h3 className="font-display text-lg font-semibold text-white">
                  {s.title}
                </h3>
              </div>
              <p className="mt-3 text-sm leading-relaxed text-gray-400">
                {s.desc}
              </p>
            </motion.div>
          ))}
        </div>

        {/* Code example */}
        <motion.div
          variants={fadeUp}
          className="mx-auto mt-16 max-w-2xl overflow-hidden rounded-xl border border-white/10 bg-[#111113]"
        >
          <div className="flex items-center gap-2 border-b border-white/5 px-5 py-3">
            <Terminal size={14} className="text-gray-500" />
            <span className="text-xs font-medium text-gray-500">
              python
            </span>
          </div>
          <pre className="overflow-x-auto p-5 text-sm leading-7">
            <code>
              <span className="text-gray-500">{"# "}</span>
              <span className="text-gray-500">Extract pricing data from any site</span>
              {"\n"}
              <span className="text-blue-400">result</span>
              <span className="text-gray-300">{" = "}</span>
              <span className="text-blue-400">await</span>
              <span className="text-gray-300">{" pokant."}</span>
              <span className="text-emerald-400">run_task</span>
              <span className="text-gray-300">{"("}</span>
              {"\n"}
              <span className="text-gray-300">{"    url"}</span>
              <span className="text-gray-500">{"="}</span>
              <span className="text-amber-300">{'"https://example.com"'}</span>
              <span className="text-gray-300">{","}</span>
              {"\n"}
              <span className="text-gray-300">{"    task"}</span>
              <span className="text-gray-500">{"="}</span>
              <span className="text-amber-300">{'"Extract all pricing plans"'}</span>
              <span className="text-gray-300">{","}</span>
              {"\n"}
              <span className="text-gray-300">{"    schema"}</span>
              <span className="text-gray-500">{"="}</span>
              <span className="text-gray-300">{"{"}</span>
              <span className="text-amber-300">{'"plans"'}</span>
              <span className="text-gray-300">{": [{"}</span>
              <span className="text-amber-300">{'"name"'}</span>
              <span className="text-gray-300">{": "}</span>
              <span className="text-amber-300">{'"str"'}</span>
              <span className="text-gray-300">{", "}</span>
              <span className="text-amber-300">{'"price"'}</span>
              <span className="text-gray-300">{": "}</span>
              <span className="text-amber-300">{'"float"'}</span>
              <span className="text-gray-300">{"}]}"}</span>
              {"\n"}
              <span className="text-gray-300">{")"}</span>
            </code>
          </pre>
        </motion.div>
      </div>
    </Section>
  )
}

