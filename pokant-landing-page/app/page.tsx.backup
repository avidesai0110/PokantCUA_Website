"use client"

import { useState } from "react"
import { motion } from "motion/react"
import { Marquee } from "@/components/ui/marquee"
import {
  Globe,
  RefreshCw,
  TrendingDown,
  Send,
  Cpu,
  FileJson,
  Shield,
  Zap,
  Eye,
  Check,
  Menu,
  X,
  ArrowRight,
  Terminal,
} from "lucide-react"

/* ─── animation helpers ─── */
const ease = [0.25, 0.4, 0.25, 1] as const
const fadeUp = { hidden: { opacity: 0, y: 24 }, visible: { opacity: 1, y: 0 } }
const fadeIn = { hidden: { opacity: 0 }, visible: { opacity: 1 } }

function Section({
  children,
  className = "",
  id,
}: {
  children: React.ReactNode
  className?: string
  id?: string
}) {
  return (
    <motion.section
      id={id}
      initial="hidden"
      whileInView="visible"
      viewport={{ once: true, amount: 0.15 }}
      transition={{ staggerChildren: 0.1 }}
      className={className}
    >
      {children}
    </motion.section>
  )
}

/* ─── Nav ─── */
function Nav() {
  const [open, setOpen] = useState(false)
  const links = [
    { label: "Features", href: "#features" },
    { label: "How It Works", href: "#how-it-works" },
    { label: "Enterprise", href: "#enterprise" },
    { label: "Pricing", href: "#pricing" },
  ]

  return (
    <nav className="fixed inset-x-0 top-0 z-50 border-b border-white/5 bg-black/60 backdrop-blur-xl">
      <div className="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
        <a href="#" className="font-display text-xl font-bold tracking-tight text-white">
          Pokant
        </a>

        {/* Desktop */}
        <div className="hidden items-center gap-8 md:flex">
          {links.map((l) => (
            <a
              key={l.label}
              href={l.href}
              className="text-sm text-gray-400 transition hover:text-white"
            >
              {l.label}
            </a>
          ))}
        </div>
        <div className="hidden items-center gap-4 md:flex">
          <a href="#" className="text-sm text-gray-400 transition hover:text-white">
            GitHub
          </a>
          <a
            href="#"
            className="rounded-lg bg-blue-600 px-5 py-2 text-sm font-medium text-white transition hover:bg-blue-700"
          >
            Get Started
          </a>
        </div>

        {/* Mobile toggle */}
        <button
          onClick={() => setOpen(!open)}
          className="text-gray-400 md:hidden"
          aria-label="Toggle menu"
        >
          {open ? <X size={22} /> : <Menu size={22} />}
        </button>
      </div>

      {/* Mobile dropdown */}
      {open && (
        <div className="border-t border-white/5 bg-black/90 px-6 pb-6 pt-4 md:hidden">
          {links.map((l) => (
            <a
              key={l.label}
              href={l.href}
              onClick={() => setOpen(false)}
              className="block py-2 text-sm text-gray-400 transition hover:text-white"
            >
              {l.label}
            </a>
          ))}
          <div className="mt-4 flex flex-col gap-3">
            <a href="#" className="text-sm text-gray-400">
              GitHub
            </a>
            <a
              href="#"
              className="rounded-lg bg-blue-600 px-5 py-2.5 text-center text-sm font-medium text-white"
            >
              Get Started
            </a>
          </div>
        </div>
      )}
    </nav>
  )
}

/* ─── Hero ─── */
function Hero() {
  return (
    <section className="relative flex min-h-screen items-center justify-center overflow-hidden pt-16">
      {/* z-0: animated gradient */}
      <div
        className="absolute inset-0 z-0"
        style={{
          background:
            "radial-gradient(ellipse 80% 50% at 50% -20%, rgba(59,130,246,0.15), transparent 70%), radial-gradient(ellipse 60% 40% at 80% 50%, rgba(59,130,246,0.08), transparent 60%), radial-gradient(ellipse 60% 40% at 20% 80%, rgba(59,130,246,0.06), transparent 60%)",
        }}
      />

      {/* z-10: dot grid with radial mask */}
      <div
        className="absolute inset-0 z-10 opacity-40"
        style={{
          backgroundImage:
            "radial-gradient(rgba(255,255,255,0.15) 1px, transparent 1px)",
          backgroundSize: "24px 24px",
          maskImage:
            "radial-gradient(ellipse 70% 60% at 50% 50%, black 30%, transparent 100%)",
          WebkitMaskImage:
            "radial-gradient(ellipse 70% 60% at 50% 50%, black 30%, transparent 100%)",
        }}
      />

      {/* z-20: floating glow blobs */}
      <div className="absolute inset-0 z-20 overflow-hidden">
        <div
          className="absolute -left-32 top-1/4 h-[500px] w-[500px] rounded-full bg-blue-500/20 blur-[120px]"
          style={{ animation: "float-blob-1 12s ease-in-out infinite" }}
        />
        <div
          className="absolute -right-32 top-1/3 h-[400px] w-[400px] rounded-full bg-blue-600/15 blur-[100px]"
          style={{ animation: "float-blob-2 15s ease-in-out infinite" }}
        />
        <div
          className="absolute bottom-1/4 left-1/3 h-[350px] w-[350px] rounded-full bg-blue-400/10 blur-[100px]"
          style={{ animation: "float-blob-3 18s ease-in-out infinite" }}
        />
      </div>

      {/* z-30: content */}
      <div className="relative z-30 mx-auto max-w-5xl px-6 text-center">
        <motion.div
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ duration: 0.8, ease }}
        >
          <h1 className="font-display text-5xl font-bold leading-[1.05] tracking-tight text-white md:text-7xl lg:text-8xl">
            Give your agents
            <br />
            access to the{" "}
            <span className="relative inline-block">
              <span className="relative z-10 bg-gradient-to-r from-blue-400 via-blue-300 to-blue-500 bg-clip-text text-transparent">
                entire web
              </span>
              <span className="absolute -inset-x-3 -inset-y-1 z-0 rounded-lg bg-blue-500/15" />
            </span>
          </h1>
        </motion.div>

        <motion.p
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ duration: 0.8, delay: 0.15, ease }}
          className="mx-auto mt-8 max-w-2xl text-lg leading-relaxed text-gray-400 md:text-xl"
        >
          One API to automate any browser workflow. AI-powered navigation,
          adaptive retries, and structured output — production-ready from day one.
        </motion.p>

        <motion.div
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ duration: 0.8, delay: 0.3, ease }}
          className="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row"
        >
          <a
            href="#"
            className="rounded-lg bg-blue-600 px-8 py-3 font-medium text-white transition hover:bg-blue-700"
          >
            Get API Key
          </a>
          <a
            href="#"
            className="rounded-lg border border-white/20 px-8 py-3 text-gray-300 transition hover:border-white/40"
          >
            View Docs
          </a>
        </motion.div>

        <motion.p
          initial={{ opacity: 0 }}
          animate={{ opacity: 1 }}
          transition={{ duration: 0.8, delay: 0.45, ease }}
          className="mt-10 text-sm text-gray-500"
        >
          Powering browser automation for developers and enterprises
        </motion.p>
      </div>
    </section>
  )
}

/* ─── Trust Bar ─── */
const tools = [
  "Browser Use",
  "Playwright",
  "Puppeteer",
  "Claude",
  "GPT-4o",
