    <Section className="border-y border-white/5 py-10">
      <motion.p
        variants={fadeIn}
        className="mb-6 text-center text-xs font-medium uppercase tracking-[0.2em] text-gray-500"
      >
        Works with the tools you already use
      </motion.p>
      <motion.div variants={fadeIn}>
        <Marquee pauseOnHover className="[--duration:30s]">
          {tools.map((t) => (
            <span
              key={t}
              className="mx-4 whitespace-nowrap text-sm font-medium text-gray-500"
            >
              {t}
            </span>
          ))}
        </Marquee>
      </motion.div>
    </Section>
