}

/* ─── Features ─── */
const features = [
  {
    icon: Globe,
    title: "Automate Any Website",
    desc: "Send a URL and a task in plain English. Get structured JSON back. No scripts, no selectors, no maintenance.",
  },
  {
    icon: RefreshCw,
